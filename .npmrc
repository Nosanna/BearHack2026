# Expo + React Native expect a flat-ish node_modules; without these,
# Metro can fail to resolve transitive deps like @babel/runtime/helpers/*.
# Hoist react-native, expo, and babel runtime helpers up to the workspace root.
public-hoist-pattern[]=*react-native*
public-hoist-pattern[]=*expo*
public-hoist-pattern[]=@babel/*
public-hoist-pattern[]=metro*
public-hoist-pattern[]=*hermes*
public-hoist-pattern[]=*reanimated*

# Resolve peer deps automatically (Expo's RN versions don't always perfectly satisfy peers)
auto-install-peers=true
strict-peer-dependencies=false

# Make symlinks resolvable in Metro / RN tooling
node-linker=isolated
shamefully-hoist=true
