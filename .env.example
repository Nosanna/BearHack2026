# Root .env.example — copy to apps/api/.env for local dev.
# Mobile reads its own values from apps/mobile/app.config.ts via expo-constants.

# ---- Database ----
DATABASE_URL="postgresql://fixit:fixit@localhost:5432/fixit?schema=public"

# ---- Redis ----
REDIS_HOST=localhost
REDIS_PORT=6379

# ---- API ----
API_PORT=4000
API_PUBLIC_URL=http://localhost:4000

# ---- JWT ----
JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# ---- Google OAuth (used to verify ID tokens from the mobile app) ----
GOOGLE_CLIENT_ID_IOS=xxxx.apps.googleusercontent.com
GOOGLE_CLIENT_ID_ANDROID=xxxx.apps.googleusercontent.com
GOOGLE_CLIENT_ID_WEB=xxxx.apps.googleusercontent.com

# ---- Gemini ----
GEMINI_API_KEY=
# Comma-separated fallback chain — tried in order on quota / rate-limit /
# transient errors. Default chain is 2.5-flash → 2.5-flash-lite → 2.0-flash →
# 2.0-flash-lite, picking up extra daily quota when the primary is exhausted.
# GEMINI_PLANNER_MODELS=gemini-2.5-flash,gemini-2.5-flash-lite,gemini-2.0-flash,gemini-2.0-flash-lite
# GEMINI_VISION_MODELS=gemini-2.5-flash,gemini-2.5-flash-lite,gemini-2.0-flash,gemini-2.0-flash-lite
# Legacy single-model knobs (still honored when *_MODELS are unset).
# GEMINI_PLANNER_MODEL=gemini-2.5-flash
# GEMINI_VISION_MODEL=gemini-2.5-flash
# Hard timeout for any single Gemini API call; fail fast instead of hanging.
GEMINI_TIMEOUT_MS=30000

# ---- Google Vision (optional; improves appliance scan) ----
GOOGLE_VISION_API_KEY=

# ---- ElevenLabs (Voice) ----
ELEVENLABS_API_KEY=
# Optional: pick a voice. Defaults to a common public voice id if unset.
ELEVENLABS_VOICE_ID=
ELEVENLABS_STT_MODEL=scribe_v2
ELEVENLABS_TTS_MODEL=eleven_multilingual_v2

# ---- Vultr Object Storage (S3-compatible) ----
S3_ENDPOINT=https://ewr1.vultrobjects.com
S3_REGION=ewr1
S3_BUCKET=fixit-fred-dev
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_FORCE_PATH_STYLE=true
S3_SIGNED_URL_TTL_SECONDS=900

# ---- Mobile (also referenced by app.config.ts via process.env) ----
EXPO_PUBLIC_API_URL=http://localhost:4000
EXPO_PUBLIC_GOOGLE_CLIENT_ID_IOS=
EXPO_PUBLIC_GOOGLE_CLIENT_ID_ANDROID=
EXPO_PUBLIC_GOOGLE_CLIENT_ID_WEB=
