DATABASE_URL="postgresql://fixit:fixit@localhost:5432/fixit?schema=public"

REDIS_HOST=localhost
REDIS_PORT=6379

API_PORT=4000
API_PUBLIC_URL=http://localhost:4000
NODE_ENV=development

JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

GOOGLE_CLIENT_ID_IOS=
GOOGLE_CLIENT_ID_ANDROID=
GOOGLE_CLIENT_ID_WEB=

GEMINI_API_KEY=
GEMINI_PLANNER_MODEL=gemini-2.5-flash
GEMINI_VISION_MODEL=gemini-2.5-flash
# Hard timeout for any single Gemini API call; fail fast instead of hanging.
GEMINI_TIMEOUT_MS=30000

S3_ENDPOINT=https://ewr1.vultrobjects.com
S3_REGION=ewr1
S3_BUCKET=fixit-fred-dev
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_FORCE_PATH_STYLE=true
S3_SIGNED_URL_TTL_SECONDS=900

THROTTLE_TTL_SECONDS=60
THROTTLE_LIMIT=120
