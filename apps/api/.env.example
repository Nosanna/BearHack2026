# Comma-separated fallback chain — each model is tried in order on quota /
# rate-limit / transient errors. Leave commented to use the built-in default
# chain (2.5-flash → 2.5-flash-lite → 2.0-flash → 2.0-flash-lite).
# GEMINI_PLANNER_MODELS=gemini-2.5-flash,gemini-2.5-flash-lite,gemini-2.0-flash,gemini-2.0-flash-lite
# GEMINI_VISION_MODELS=gemini-2.5-flash,gemini-2.5-flash-lite,gemini-2.0-flash,gemini-2.0-flash-lite
# Legacy single-model knobs (still honored if the *_MODELS variants are unset):
# GEMINI_PLANNER_MODEL=gemini-2.5-flash
# GEMINI_VISION_MODEL=gemini-2.5-flash
# Hard timeout for any single Gemini API call; fail fast instead of hanging.
GEMINI_TIMEOUT_MS=30000

